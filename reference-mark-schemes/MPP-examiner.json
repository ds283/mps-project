{
  "scheme": [
    {
      "title": "Preamble",
      "fields": [
        {
          "key": "conflict",
          "text": "Please check to indicate that you have no conflict of interest in marking this report.",
          "field_type": {
            "type": "boolean"
          }
        },
        {
          "key": "send",
          "text": "Please check to indicate that your final assigned grade accounts for any reasonable adjustments indicated. These may appear on an attached electronic sticker.",
          "field_type": {
            "type": "boolean"
          }
        }
      ]
    },
    {
      "title": "Marking report",
      "fields": [
        {
          "key": "structure",
          "text": "Structure and presentation",
          "field_type": {
            "type": "number",
            "min": 0,
            "max": 10
          }
        },
        {
          "key": "clarity",
          "text": "Clarity of presentation",
          "field_type": {
            "type": "number",
            "min": 0,
            "max": 10
          }
        },
        {
          "key": "quality",
          "text": "Quality",
          "field_type": {
            "type": "number",
            "min": 0,
            "max": 10
          }
        },
        {
          "key": "results",
          "text": "Results and their wider significance",
          "field_type": {
            "type": "number",
            "min": 0,
            "max": 10
          }
        }
      ]
    }
  ],
  "validation": [
    {
      "test": "not conflict",
      "action": [
        "prevent_submit"
      ]
    }
  ],
  "conflation_rule": "(1.0*structure + 3.0*clarity + 3.0quality + 3.0*results)"
}